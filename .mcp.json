{
  "mcpServers": {
    "tradingview": {
      "command": "node",
      "args": ["./src/server.js"]
    },
    "tool-router": {
      "command": "npx",
      "args": ["tool-router-mcp"]
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "telegram": {
      "command": "bun",
      "args": ["run", "--cwd", "C:/Users/Reef/.claude/plugins/marketplaces/claude-plugins-official/external_plugins/telegram", "--shell=bun", "--silent", "start"]
    }
  }
}
