//@version=6
strategy("Session NPOCs + Pre-Trade Checklist | 21/200 MA",
         overlay          = true,
         max_lines_count  = 500,
         max_labels_count = 500,
         max_bars_back    = 5000,
         initial_capital  = 10000,
         default_qty_type = strategy.percent_of_equity,
         default_qty_value = 100,
         commission_type  = strategy.commission.percent,
         commission_value = 0.05)

// ═══════════════════════════════════════════════════════════════════════════════
// SESSIONS
// ═══════════════════════════════════════════════════════════════════════════════
grp_s = "Sessions"
show_daily = input.bool(true, "Daily (00:00–00:00 UTC)",  group=grp_s)
show_asian = input.bool(true, "Asian (00:00–08:00 UTC)",  group=grp_s)
show_ny    = input.bool(true, "NY (13:30–22:00 UTC)",     group=grp_s)
show_va    = input.bool(true, "Show VAH / VAL",            group=grp_s)

// ═══════════════════════════════════════════════════════════════════════════════
// DISPLAY
// ═══════════════════════════════════════════════════════════════════════════════
grp_d = "Display"
max_npoc    = input.int(5,     "Last N POCs to show per session",   group=grp_d, minval=1, maxval=20)
lookback    = input.int(14,    "History (days)",                    group=grp_d, minval=1, maxval=60)
show_naked  = input.bool(true, "Show Naked POCs",                   group=grp_d)
show_filled = input.bool(true, "Show Touched POCs",                 group=grp_d)

// ═══════════════════════════════════════════════════════════════════════════════
// VOLUME PROFILE
// ═══════════════════════════════════════════════════════════════════════════════
grp_vp = "Volume Profile"
bkt_sz = input.float(100.0, "Bucket Size ($)", group=grp_vp, minval=1.0, step=10.0,
         tooltip="Price increment per bucket. Use 50–200 for BTC.")
va_pct = input.float(70.0,  "Value Area %",   group=grp_vp, minval=50.0, maxval=95.0, step=5.0)

// ═══════════════════════════════════════════════════════════════════════════════
// STYLE
// ═══════════════════════════════════════════════════════════════════════════════
grp_c = "Style"
npoc_col   = input.color(color.orange,                "Naked POC",  group=grp_c)
filled_col = input.color(color.new(color.gray, 50),   "Filled POC", group=grp_c)
vah_col    = input.color(color.new(color.teal, 20),   "VAH",        group=grp_c)
val_col    = input.color(color.new(color.purple, 20), "VAL",        group=grp_c)

// ═══════════════════════════════════════════════════════════════════════════════
// MOVING AVERAGES  (21 / 200)
// ═══════════════════════════════════════════════════════════════════════════════
grp_ma = "Moving Averages"
ma_fast_len = input.int(21,  "Fast MA (21)",  group=grp_ma, minval=1)
ma_slow_len = input.int(200, "Slow MA (200)", group=grp_ma, minval=1)
ma_type     = input.string("EMA", "MA Type",  group=grp_ma, options=["EMA", "SMA"])

ma_fast  = ma_type == "EMA" ? ta.ema(close, ma_fast_len) : ta.sma(close, ma_fast_len)
ma_slow  = ma_type == "EMA" ? ta.ema(close, ma_slow_len) : ta.sma(close, ma_slow_len)
ma_200s  = ta.sma(close, 200)
ma_800s  = ta.sma(close, 800)

plot(ma_fast,  "21 MA",      color=color.new(color.aqua,   0), linewidth=1)
plot(ma_slow,  "200 MA",     color=color.new(color.red,    0), linewidth=2)
plot(ma_200s,  "200 SMA",    color=color.new(color.yellow, 0), linewidth=1, style=plot.style_line)
plot(ma_800s,  "800 SMA",    color=color.new(color.fuchsia,0), linewidth=2, style=plot.style_line)

// ═══════════════════════════════════════════════════════════════════════════════
// RSI
// ═══════════════════════════════════════════════════════════════════════════════
grp_rsi = "RSI"
rsi_len = input.int(14, "RSI Length", group=grp_rsi, minval=1)
rsi_val = ta.rsi(close, rsi_len)

// ═══════════════════════════════════════════════════════════════════════════════
// MACD
// ═══════════════════════════════════════════════════════════════════════════════
grp_macd = "MACD"
macd_fast_len = input.int(12, "Fast Length",   group=grp_macd, minval=1)
macd_slow_len2= input.int(26, "Slow Length",   group=grp_macd, minval=1)
macd_sig_len  = input.int(9,  "Signal Length", group=grp_macd, minval=1)

[macd_line, macd_signal_line, macd_hist] = ta.macd(close, macd_fast_len, macd_slow_len2, macd_sig_len)

// ═══════════════════════════════════════════════════════════════════════════════
// STOCHASTIC
// ═══════════════════════════════════════════════════════════════════════════════
grp_stoch = "Stochastic"
stoch_k_len  = input.int(14, "K Length",    group=grp_stoch, minval=1)
stoch_d_len  = input.int(3,  "D Smoothing", group=grp_stoch, minval=1)
stoch_sm_len = input.int(3,  "K Smoothing", group=grp_stoch, minval=1)

stoch_k = ta.sma(ta.stoch(close, high, low, stoch_k_len), stoch_sm_len)
stoch_d = ta.sma(stoch_k, stoch_d_len)

// ═══════════════════════════════════════════════════════════════════════════════
// ENTRY FRAMEWORK
// ═══════════════════════════════════════════════════════════════════════════════
grp_e = "Entry Framework"
proximity_mult = input.float(1.0,  "NPOC Proximity (× bucket size)", group=grp_e, minval=0.1, step=0.1,
                tooltip="How close price must be to a Naked POC to trigger. 1.0 = within one bucket.")
sl_atr_mult    = input.float(1.5,  "Stop Loss (× ATR)",              group=grp_e, minval=0.1, step=0.1)
tp_rr          = input.float(2.0,  "Take Profit (R:R ratio)",        group=grp_e, minval=0.1, step=0.1)
atr_len        = input.int(14,     "ATR Length",                     group=grp_e, minval=1)
use_alerts     = input.bool(false, "Enable Alerts",                   group=grp_e)

atr_val   = ta.atr(atr_len)
proximity = bkt_sz * proximity_mult

// ═══════════════════════════════════════════════════════════════════════════════
// PRE-TRADE CHECKLIST SETTINGS
// ═══════════════════════════════════════════════════════════════════════════════
grp_cl = "Pre-Trade Checklist"
min_score  = input.int(6,    "Min Score to Enter (1–9)", group=grp_cl, minval=1, maxval=9,
             tooltip="How many of the 9 checklist items must pass to trigger an entry.")
swing_lb   = input.int(20,   "Swing Lookback (bars)",    group=grp_cl, minval=5, maxval=100)
show_table = input.bool(true,"Show Checklist Table",     group=grp_cl)
use_c1     = input.bool(true, "1 · Bullish pattern (price > 21 MA)",              group=grp_cl)
use_c2     = input.bool(true, "2 · Price at bottom of trend line (near support)", group=grp_cl)
use_c3     = input.bool(true, "3 · Price in last 25% of pattern",                 group=grp_cl)
use_c4     = input.bool(true, "4 · MACD histogram turning bullish/bearish",       group=grp_cl)
use_c5     = input.bool(true, "5 · MACD line curving toward signal",              group=grp_cl)
use_c6     = input.bool(true, "6 · RSI + Stoch below/above 50",                  group=grp_cl)
use_c7     = input.bool(true, "7 · 21 MA curving toward 200 MA",                 group=grp_cl)
use_c8     = input.bool(false,"8 · Divergence (RSI vs price)",                   group=grp_cl)
use_c9     = input.bool(true, "9 · Near NPOC support/resistance",                group=grp_cl)

// ═══════════════════════════════════════════════════════════════════════════════
// SESSION DETECTION (UTC)
// ═══════════════════════════════════════════════════════════════════════════════
int  t_hm     = hour(time, "UTC") * 100 + minute(time, "UTC")
bool in_asian = t_hm >= 0    and t_hm < 800
bool in_ny    = t_hm >= 1330 and t_hm < 2200

bool new_day    = ta.change(time("D")) != 0
bool asian_open = in_asian and not in_asian[1]
bool asian_clos = not in_asian and in_asian[1]
bool ny_open    = in_ny    and not in_ny[1]
bool ny_clos    = not in_ny    and in_ny[1]

// ═══════════════════════════════════════════════════════════════════════════════
// VOLUME PROFILE ACCUMULATORS
// ═══════════════════════════════════════════════════════════════════════════════
var map<int,float> d_m = map.new<int,float>()
var map<int,float> a_m = map.new<int,float>()
var map<int,float> n_m = map.new<int,float>()

var int d_bar0 = na
var int a_bar0 = na
var int n_bar0 = na
var int d_t0   = na
var int a_t0   = na
var int n_t0   = na

// ═══════════════════════════════════════════════════════════════════════════════
// COMPLETED LEVEL STORAGE
// ═══════════════════════════════════════════════════════════════════════════════
var float[]  st_poc    = array.new_float()
var float[]  st_vah    = array.new_float()
var float[]  st_val    = array.new_float()
var string[] st_sess   = array.new_string()
var bool[]   st_pfill  = array.new_bool()
var bool[]   st_vfill  = array.new_bool()
var int[]    st_bar0   = array.new_int()
var int[]    st_t0     = array.new_int()
var bool[]   st_has_va = array.new_bool()
var line[]   st_pln    = array.new_line()
var label[]  st_plb    = array.new_label()
var line[]   st_vhln   = array.new_line()
var line[]   st_vlln   = array.new_line()
var label[]  st_vhlb   = array.new_label()
var label[]  st_vllb   = array.new_label()

// ═══════════════════════════════════════════════════════════════════════════════
// HELPER FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

addBar(map<int,float> m, float b_lo, float b_hi, float b_vol) =>
    int lo_b = math.floor(b_lo / bkt_sz)
    int hi_b = math.floor(b_hi / bkt_sz)
    int cnt  = math.max(1, hi_b - lo_b + 1)
    float vpb = b_vol / cnt
    for i = lo_b to hi_b
        float cur = na(map.get(m, i)) ? 0.0 : map.get(m, i)
        map.put(m, i, cur + vpb)

calcPOC(map<int,float> m) =>
    float mx = 0.0
    int   pb = na
    for [k, v] in m
        if v > mx
            mx := v
            pb := k
    na(pb) ? na : (pb + 0.5) * bkt_sz

calcVA(map<int,float> m, float poc_p) =>
    float vah_r = na
    float val_r = na
    if not na(poc_p)
        int   poc_b  = math.floor(poc_p / bkt_sz)
        float total  = 0.0
        for [k, v] in m
            total += v
        float target = total * (va_pct / 100.0)
        float accum  = na(map.get(m, poc_b)) ? 0.0 : map.get(m, poc_b)
        int   lo_b   = poc_b
        int   hi_b   = poc_b
        int   guard  = 0
        while accum < target and guard < 500
            float up = na(map.get(m, hi_b+1)) ? 0.0 : map.get(m, hi_b+1)
            float dn = na(map.get(m, lo_b-1)) ? 0.0 : map.get(m, lo_b-1)
            if up == 0.0 and dn == 0.0
                break
            if up >= dn
                hi_b  += 1
                accum += up
            else
                lo_b  -= 1
                accum += dn
            guard += 1
        vah_r := (hi_b + 1) * bkt_sz
        val_r :=  lo_b      * bkt_sz
    [vah_r, val_r]

countTotal(string stype) =>
    int cnt = 0
    int sz  = array.size(st_sess)
    if sz > 0
        for i = 0 to sz - 1
            if array.get(st_sess, i) == stype
                cnt += 1
    cnt

pruneOldest(string stype) =>
    int sz = array.size(st_sess)
    if sz > 0
        for i = 0 to sz - 1
            if array.get(st_sess, i) == stype
                line.delete(array.get(st_pln, i))
                label.delete(array.get(st_plb, i))
                if array.get(st_has_va, i)
                    line.delete(array.get(st_vhln, i))
                    line.delete(array.get(st_vlln, i))
                    label.delete(array.get(st_vhlb, i))
                    label.delete(array.get(st_vllb, i))
                array.remove(st_poc,    i)
                array.remove(st_vah,    i)
                array.remove(st_val,    i)
                array.remove(st_sess,   i)
                array.remove(st_pfill,  i)
                array.remove(st_vfill,  i)
                array.remove(st_bar0,   i)
                array.remove(st_t0,     i)
                array.remove(st_has_va, i)
                array.remove(st_pln,    i)
                array.remove(st_plb,    i)
                array.remove(st_vhln,   i)
                array.remove(st_vlln,   i)
                array.remove(st_vhlb,   i)
                array.remove(st_vllb,   i)
                break

commitSession(map<int,float> m, string stype, int bar0, int t0) =>
    float poc_p = calcPOC(m)
    if not na(poc_p)
        [vah_p, val_p] = calcVA(m, poc_p)
        bool has_va = show_va and not na(vah_p) and not na(val_p)

        if countTotal(stype) >= max_npoc
            pruneOldest(stype)

        line ln_p = line.new(bar0, poc_p, bar_index, poc_p,
                             xloc=xloc.bar_index, extend=extend.none,
                             color=npoc_col, width=1, style=line.style_dashed)
        label lb_p = label.new(bar_index, poc_p,
                               stype + " NPoc  " + str.tostring(math.round(poc_p)),
                               xloc=xloc.bar_index, yloc=yloc.price,
                               style=label.style_label_left,
                               color=color.new(npoc_col, 15),
                               textcolor=color.white, size=size.small)

        line  ln_vh = na
        line  ln_vl = na
        label lb_vh = na
        label lb_vl = na
        if has_va
            ln_vh := line.new(bar0, vah_p, bar_index, vah_p,
                              xloc=xloc.bar_index, extend=extend.none,
                              color=vah_col, width=1, style=line.style_dotted)
            ln_vl := line.new(bar0, val_p, bar_index, val_p,
                              xloc=xloc.bar_index, extend=extend.none,
                              color=val_col, width=1, style=line.style_dotted)
            lb_vh := label.new(bar_index, vah_p,
                               stype + " VAH  " + str.tostring(math.round(vah_p)),
                               xloc=xloc.bar_index, yloc=yloc.price,
                               style=label.style_label_left,
                               color=color.new(vah_col, 40),
                               textcolor=color.white, size=size.tiny)
            lb_vl := label.new(bar_index, val_p,
                               stype + " VAL  " + str.tostring(math.round(val_p)),
                               xloc=xloc.bar_index, yloc=yloc.price,
                               style=label.style_label_left,
                               color=color.new(val_col, 40),
                               textcolor=color.white, size=size.tiny)

        array.push(st_poc,    poc_p)
        array.push(st_vah,    has_va ? vah_p : na)
        array.push(st_val,    has_va ? val_p : na)
        array.push(st_sess,   stype)
        array.push(st_pfill,  false)
        array.push(st_vfill,  false)
        array.push(st_bar0,   bar0)
        array.push(st_t0,     t0)
        array.push(st_has_va, has_va)
        array.push(st_pln,    ln_p)
        array.push(st_plb,    lb_p)
        array.push(st_vhln,   ln_vh)
        array.push(st_vlln,   ln_vl)
        array.push(st_vhlb,   lb_vh)
        array.push(st_vllb,   lb_vl)

// Table cell helpers
f_chk(bool v) => v ? "✓" : "✗"
f_clr(bool v) => v ? color.new(color.lime, 30) : color.new(color.red, 50)

// ═══════════════════════════════════════════════════════════════════════════════
// ACCUMULATE PROFILES
// ═══════════════════════════════════════════════════════════════════════════════

if new_day
    if show_daily and not na(d_bar0) and map.size(d_m) > 0
        commitSession(d_m, "D", d_bar0, d_t0)
    d_m    := map.new<int,float>()
    d_bar0 := bar_index
    d_t0   := time
addBar(d_m, low, high, volume)

if asian_open
    a_m    := map.new<int,float>()
    a_bar0 := bar_index
    a_t0   := time
if in_asian
    addBar(a_m, low, high, volume)
if asian_clos and show_asian and not na(a_bar0) and map.size(a_m) > 0
    commitSession(a_m, "A", a_bar0, a_t0)

if ny_open
    n_m    := map.new<int,float>()
    n_bar0 := bar_index
    n_t0   := time
if in_ny
    addBar(n_m, low, high, volume)
if ny_clos and show_ny and not na(n_bar0) and map.size(n_m) > 0
    commitSession(n_m, "N", n_bar0, n_t0)

// ═══════════════════════════════════════════════════════════════════════════════
// PER-BAR — FILL DETECTION + LINE EXTENSION + EXPIRY
// ═══════════════════════════════════════════════════════════════════════════════
int max_age_ms = lookback * 86400000

float nearest_above = na
float nearest_below = na

int n_lvl = array.size(st_poc)
if n_lvl > 0
    for i = 0 to n_lvl - 1
        float  p     = array.get(st_poc,    i)
        bool   done  = array.get(st_pfill,  i)
        bool   hva   = array.get(st_has_va, i)
        int    t0    = array.get(st_t0,     i)
        string sess  = array.get(st_sess,   i)
        line   pln   = array.get(st_pln,    i)
        label  plb   = array.get(st_plb,    i)

        bool expired = (time - t0) > max_age_ms

        if not done and low <= p and high >= p
            array.set(st_pfill, i, true)
            done := true

        if expired
            line.set_color(pln,  color.new(color.black, 100))
            label.set_color(plb, color.new(color.black, 100))
        else if done
            if show_filled
                line.set_color(pln,  filled_col)
                line.set_style(pln,  line.style_solid)
                line.set_x2(pln,     bar_index)
                label.set_color(plb, filled_col)
                label.set_text(plb,  sess + " ✓POC  " + str.tostring(math.round(p)))
                label.set_x(plb,     bar_index)
            else
                line.set_color(pln,  color.new(color.black, 100))
                label.set_color(plb, color.new(color.black, 100))
        else
            if show_naked
                line.set_color(pln,  npoc_col)
                line.set_style(pln,  line.style_dashed)
                line.set_x2(pln,     bar_index)
                label.set_color(plb, color.new(npoc_col, 15))
                label.set_x(plb,     bar_index)
            else
                line.set_color(pln,  color.new(color.black, 100))
                label.set_color(plb, color.new(color.black, 100))

            if p > close
                nearest_above := na(nearest_above) ? p : math.min(nearest_above, p)
            else if p < close
                nearest_below := na(nearest_below) ? p : math.max(nearest_below, p)

        if hva and not expired
            float  vh    = array.get(st_vah,   i)
            float  vl    = array.get(st_val,   i)
            bool   vdone = array.get(st_vfill, i)
            line   vhln  = array.get(st_vhln,  i)
            line   vlln  = array.get(st_vlln,  i)
            label  vhlb  = array.get(st_vhlb,  i)
            label  vllb  = array.get(st_vllb,  i)

            if not vdone and (high > vh or low < vl)
                array.set(st_vfill, i, true)
                vdone := true

            if vdone
                line.set_color(vhln,  color.new(color.black, 100))
                line.set_color(vlln,  color.new(color.black, 100))
                label.set_color(vhlb, color.new(color.black, 100))
                label.set_color(vllb, color.new(color.black, 100))
            else
                line.set_x2(vhln, bar_index)
                line.set_x2(vlln, bar_index)
                label.set_x(vhlb, bar_index)
                label.set_x(vllb, bar_index)

// ═══════════════════════════════════════════════════════════════════════════════
// PRE-TRADE CHECKLIST EVALUATION
// ═══════════════════════════════════════════════════════════════════════════════

bool near_npoc_support    = not na(nearest_below) and math.abs(low  - nearest_below) <= proximity
bool near_npoc_resistance = not na(nearest_above) and math.abs(high - nearest_above) <= proximity

// 1. Bullish/bearish pattern — price above/below 21 MA
bool c1_l = close > ma_fast
bool c1_s = close < ma_fast

// 2. Price at bottom of trend line — near 21 MA pullback (dynamic support) or NPOC
bool c2_l = math.abs(close - ma_fast) <= atr_val or near_npoc_support
bool c2_s = math.abs(close - ma_fast) <= atr_val or near_npoc_resistance

// 3. Price in last 25% of pattern range
float sw_hi  = ta.highest(high, swing_lb)
float sw_lo  = ta.lowest(low,  swing_lb)
float sw_rng = sw_hi - sw_lo
bool c3_l = sw_rng > 0 and close <= sw_lo + sw_rng * 0.25
bool c3_s = sw_rng > 0 and close >= sw_hi - sw_rng * 0.25

// 4. MACD histogram turning bullish/bearish (momentum shifting)
bool c4_l = macd_hist > macd_hist[1]
bool c4_s = macd_hist < macd_hist[1]

// 5. MACD line (blue) curving up toward signal (red) — approaching from below or just crossed
bool c5_l = macd_line > macd_line[1] and (macd_line < macd_signal_line or ta.crossover(macd_line, macd_signal_line))
bool c5_s = macd_line < macd_line[1] and (macd_line > macd_signal_line or ta.crossunder(macd_line, macd_signal_line))

// 6. RSI + Stochastic below 50 (long) / above 50 (short) — near oversold/overbought
bool c6_l = rsi_val < 50.0 and stoch_k < 50.0
bool c6_s = rsi_val > 50.0 and stoch_k > 50.0

// 7. Shorter MA (21) curving toward longer MA (200) — slope positive and gap narrowing or already above
float ma_fast_slope = ma_fast  - ma_fast[5]
float ma_gap_now    = math.abs(ma_slow  - ma_fast)
float ma_gap_prev   = math.abs(ma_slow[5] - ma_fast[5])
bool c7_l = ma_fast_slope > 0 and (ma_fast > ma_slow or ma_gap_now < ma_gap_prev)
bool c7_s = ma_fast_slope < 0 and (ma_fast < ma_slow or ma_gap_now < ma_gap_prev)

// 8. Divergence — price at recent extreme but RSI diverging
float rsi_lb_low  = ta.lowest(rsi_val,  swing_lb)
float rsi_lb_high = ta.highest(rsi_val, swing_lb)
bool c8_l = low  <= sw_lo * 1.003 and rsi_val > rsi_lb_low  + 2.0
bool c8_s = high >= sw_hi * 0.997 and rsi_val < rsi_lb_high - 2.0

// 9. Near significant S/R — Naked POC level
bool c9_l = near_npoc_support
bool c9_s = near_npoc_resistance

// ═══════════════════════════════════════════════════════════════════════════════
// SCORE & SIGNAL
// ═══════════════════════════════════════════════════════════════════════════════
int l_score = (use_c1 and c1_l ? 1 : 0) + (use_c2 and c2_l ? 1 : 0) +
              (use_c3 and c3_l ? 1 : 0) + (use_c4 and c4_l ? 1 : 0) +
              (use_c5 and c5_l ? 1 : 0) + (use_c6 and c6_l ? 1 : 0) +
              (use_c7 and c7_l ? 1 : 0) + (use_c8 and c8_l ? 1 : 0) +
              (use_c9 and c9_l ? 1 : 0)

int s_score = (use_c1 and c1_s ? 1 : 0) + (use_c2 and c2_s ? 1 : 0) +
              (use_c3 and c3_s ? 1 : 0) + (use_c4 and c4_s ? 1 : 0) +
              (use_c5 and c5_s ? 1 : 0) + (use_c6 and c6_s ? 1 : 0) +
              (use_c7 and c7_s ? 1 : 0) + (use_c8 and c8_s ? 1 : 0) +
              (use_c9 and c9_s ? 1 : 0)

bool long_signal  = l_score >= min_score
bool short_signal = s_score >= min_score

// ═══════════════════════════════════════════════════════════════════════════════
// STRATEGY ENTRIES / EXITS
// ═══════════════════════════════════════════════════════════════════════════════
float sl_dist = atr_val * sl_atr_mult
float tp_dist = sl_dist * tp_rr

if long_signal and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long",
                  stop  = strategy.position_avg_price - sl_dist,
                  limit = strategy.position_avg_price + tp_dist)

if short_signal and strategy.position_size == 0
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short",
                  stop  = strategy.position_avg_price + sl_dist,
                  limit = strategy.position_avg_price - tp_dist)

// ═══════════════════════════════════════════════════════════════════════════════
// SIGNAL SHAPES ON CHART
// ═══════════════════════════════════════════════════════════════════════════════
plotshape(long_signal,  title="Long Signal",  location=location.belowbar,
          style=shape.labelup,   color=color.new(color.lime, 0),
          textcolor=color.black, text="▲ LONG", size=size.small)

plotshape(short_signal, title="Short Signal", location=location.abovebar,
          style=shape.labeldown, color=color.new(color.red, 0),
          textcolor=color.white, text="▼ SHORT", size=size.small)

// ═══════════════════════════════════════════════════════════════════════════════
// NEAREST NPOC PLOTS
// ═══════════════════════════════════════════════════════════════════════════════
plot(nearest_above, "Nearest NPoc Above", color=color.new(npoc_col, 60), linewidth=1, style=plot.style_circles)
plot(nearest_below, "Nearest NPoc Below", color=color.new(npoc_col, 60), linewidth=1, style=plot.style_circles)

// ═══════════════════════════════════════════════════════════════════════════════
// LIVE CHECKLIST TABLE  (top-right corner)
// ═══════════════════════════════════════════════════════════════════════════════
var table ck_tbl = table.new(position.top_right, 3, 11,
                             bgcolor    = color.new(color.black, 15),
                             border_width = 1, border_color = color.new(color.gray, 40),
                             frame_width  = 1, frame_color  = color.new(color.gray, 20))

if show_table and barstate.islast
    color hdr_bg = color.new(color.navy, 10)

    table.cell(ck_tbl, 0, 0, "Check",   text_color=color.white,      bgcolor=hdr_bg, text_size=size.small)
    table.cell(ck_tbl, 1, 0, "LONG",    text_color=color.lime,       bgcolor=hdr_bg, text_size=size.small)
    table.cell(ck_tbl, 2, 0, "SHORT",   text_color=color.red,        bgcolor=hdr_bg, text_size=size.small)

    table.cell(ck_tbl, 0, 1, "1·Pattern",   text_color=color.white, text_size=size.small)
    table.cell(ck_tbl, 1, 1, f_chk(c1_l),   text_color=color.white, bgcolor=f_clr(c1_l), text_size=size.small)
    table.cell(ck_tbl, 2, 1, f_chk(c1_s),   text_color=color.white, bgcolor=f_clr(c1_s), text_size=size.small)

    table.cell(ck_tbl, 0, 2, "2·Support",   text_color=color.white, text_size=size.small)
    table.cell(ck_tbl, 1, 2, f_chk(c2_l),   text_color=color.white, bgcolor=f_clr(c2_l), text_size=size.small)
    table.cell(ck_tbl, 2, 2, f_chk(c2_s),   text_color=color.white, bgcolor=f_clr(c2_s), text_size=size.small)

    table.cell(ck_tbl, 0, 3, "3·25% Zone",  text_color=color.white, text_size=size.small)
    table.cell(ck_tbl, 1, 3, f_chk(c3_l),   text_color=color.white, bgcolor=f_clr(c3_l), text_size=size.small)
    table.cell(ck_tbl, 2, 3, f_chk(c3_s),   text_color=color.white, bgcolor=f_clr(c3_s), text_size=size.small)

    table.cell(ck_tbl, 0, 4, "4·MACD Turn", text_color=color.white, text_size=size.small)
    table.cell(ck_tbl, 1, 4, f_chk(c4_l),   text_color=color.white, bgcolor=f_clr(c4_l), text_size=size.small)
    table.cell(ck_tbl, 2, 4, f_chk(c4_s),   text_color=color.white, bgcolor=f_clr(c4_s), text_size=size.small)

    table.cell(ck_tbl, 0, 5, "5·MACD Curl", text_color=color.white, text_size=size.small)
    table.cell(ck_tbl, 1, 5, f_chk(c5_l),   text_color=color.white, bgcolor=f_clr(c5_l), text_size=size.small)
    table.cell(ck_tbl, 2, 5, f_chk(c5_s),   text_color=color.white, bgcolor=f_clr(c5_s), text_size=size.small)

    table.cell(ck_tbl, 0, 6, "6·RSI/Stoch", text_color=color.white, text_size=size.small)
    table.cell(ck_tbl, 1, 6, f_chk(c6_l),   text_color=color.white, bgcolor=f_clr(c6_l), text_size=size.small)
    table.cell(ck_tbl, 2, 6, f_chk(c6_s),   text_color=color.white, bgcolor=f_clr(c6_s), text_size=size.small)

    table.cell(ck_tbl, 0, 7, "7·MA Curl",   text_color=color.white, text_size=size.small)
    table.cell(ck_tbl, 1, 7, f_chk(c7_l),   text_color=color.white, bgcolor=f_clr(c7_l), text_size=size.small)
    table.cell(ck_tbl, 2, 7, f_chk(c7_s),   text_color=color.white, bgcolor=f_clr(c7_s), text_size=size.small)

    table.cell(ck_tbl, 0, 8, "8·Diverge",   text_color=color.white, text_size=size.small)
    table.cell(ck_tbl, 1, 8, f_chk(c8_l),   text_color=color.white, bgcolor=f_clr(c8_l), text_size=size.small)
    table.cell(ck_tbl, 2, 8, f_chk(c8_s),   text_color=color.white, bgcolor=f_clr(c8_s), text_size=size.small)

    table.cell(ck_tbl, 0, 9, "9·NPOC S/R",  text_color=color.white, text_size=size.small)
    table.cell(ck_tbl, 1, 9, f_chk(c9_l),   text_color=color.white, bgcolor=f_clr(c9_l), text_size=size.small)
    table.cell(ck_tbl, 2, 9, f_chk(c9_s),   text_color=color.white, bgcolor=f_clr(c9_s), text_size=size.small)

    string l_txt = str.tostring(l_score) + "/" + str.tostring(min_score)
    string s_txt = str.tostring(s_score) + "/" + str.tostring(min_score)
    table.cell(ck_tbl, 0, 10, "Score",  text_color=color.white,  bgcolor=hdr_bg, text_size=size.small)
    table.cell(ck_tbl, 1, 10, l_txt,
               text_color = long_signal  ? color.black : color.white,
               bgcolor    = long_signal  ? color.new(color.lime, 0) : hdr_bg, text_size=size.small)
    table.cell(ck_tbl, 2, 10, s_txt,
               text_color = short_signal ? color.white : color.white,
               bgcolor    = short_signal ? color.new(color.red, 0)  : hdr_bg, text_size=size.small)

// ═══════════════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════════════
alertcondition(use_alerts and long_signal,  "Checklist Long",  "Pre-Trade Checklist LONG signal fired")
alertcondition(use_alerts and short_signal, "Checklist Short", "Pre-Trade Checklist SHORT signal fired")

// Session background shading
bgcolor(in_asian ? color.new(color.blue,   97) : na, title="Asian Session")
bgcolor(in_ny    ? color.new(color.yellow, 97) : na, title="NY Session")
