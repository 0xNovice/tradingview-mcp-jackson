// @version=5
// Crypto Lifer Strategy — Sam Price
// Part 1: 200 SMA macro bias + 21 SMA entry/exit timing ("Twisted Sister")
// Part 2: Leverage class — risk management, session filter, smooth MA, position sizing
// Polish notes left as TODO comments

strategy(
     title             = "Crypto Lifer — Full Strategy",
     shorttitle        = "CL_FULL",
     overlay           = true,
     default_qty_type  = strategy.fixed,
     default_qty_value = 1,
     commission_type   = strategy.commission.percent,
     commission_value  = 0.05,
     initial_capital   = 10000
 )

// ─── MOVING AVERAGES ─────────────────────────────────────────────────────────
ma21_len   = input.int(21,  "21 SMA Length",  group="Moving Averages")
ma50_len   = input.int(50,  "50 SMA Length",  group="Moving Averages")
ma80_len   = input.int(80,  "80 SMA Length",  group="Moving Averages")
ma100_len  = input.int(100, "100 SMA Length", group="Moving Averages")
ma200_len  = input.int(200, "200 SMA Length", group="Moving Averages")
smooth_len = input.int(50,  "Smooth MA Length (SMMA)", group="Moving Averages")

ma21   = ta.sma(close, ma21_len)
ma50   = ta.sma(close, ma50_len)
ma80   = ta.sma(close, ma80_len)
ma100  = ta.sma(close, ma100_len)
ma200  = ta.sma(close, ma200_len)

// Smooth MA (SMMA / RMA) — Sam's "smooth moving average", strong signal when price gets above it
smooth_ma = ta.rma(close, smooth_len)

plot(ma21,     "21 SMA",    color=color.white,                linewidth=2)
plot(ma50,     "50 SMA",    color=color.red,                  linewidth=1)
plot(ma80,     "80 SMA",    color=color.purple,               linewidth=1)
plot(ma100,    "100 SMA",   color=color.blue,                 linewidth=1)
plot(ma200,    "200 SMA",   color=color.yellow,               linewidth=2)
plot(smooth_ma,"Smooth MA", color=color.new(color.teal, 20),  linewidth=2)

// ─── RISK MANAGEMENT ─────────────────────────────────────────────────────────
account_size   = input.float(10000, "Account Size (USD)",        group="Risk Management")
risk_pct       = input.float(1.0,   "Risk Per Trade %",  minval=0.1, maxval=5, step=0.1, group="Risk Management")
rr_ratio       = input.float(3.0,   "Risk:Reward Target", minval=1, maxval=10, step=0.5,  group="Risk Management")
show_risk_table= input.bool(true,   "Show Risk Dashboard",        group="Risk Management")

// ─── EXIT SETTINGS ────────────────────────────────────────────────────────────
gap_pct        = input.float(2.5,  "Gap Away from 21 SMA % (Take Profit)", minval=0.5, maxval=20, step=0.5, group="Exit")
partial_pct    = input.float(75.0, "Partial Exit % at first gap",           minval=10,  maxval=100, step=5,   group="Exit")
stoch_len      = input.int(14,     "Stoch RSI Length",   group="Exit")
stoch_k        = input.int(3,      "Stoch RSI K",         group="Exit")
stoch_d        = input.int(3,      "Stoch RSI D",         group="Exit")
ob_level       = input.int(80,     "Stoch RSI Overbought Level", group="Exit")

// ─── SESSION FILTER (EST / UTC-5, EDT / UTC-4 during DST) ───────────────────
// All times below are UTC strings (TradingView time() uses UTC)
//
// Session         EST               UTC (standard)   UTC (DST/EDT)
// ─────────────── ──────────────── ──────────────── ────────────────
// Sydney          5:00 PM–2:00 AM  22:00–07:00      21:00–06:00
// Tokyo/Asia      7:00 PM–4:00 AM  00:00–09:00      23:00–08:00
// Frankfurt pre   2:00 AM–3:00 AM  07:00–08:00      06:00–07:00
// London          3:00 AM–12:00 PM 08:00–17:00      07:00–16:00
// Tokyo-London OL 3:00 AM–4:00 AM  08:00–09:00      07:00–08:00
// New York        8:00 AM–5:00 PM  13:00–22:00      12:00–21:00
// London-NY OL    8:00 AM–12:00 PM 13:00–17:00      12:00–16:00  ← BEST
// Sam Mon night   6:00 PM–9:00 PM  23:00–02:00      22:00–01:00
// Sam Tue–Wed     7:00 AM–12:00 PM 12:00–17:00      11:00–16:00
//
// DST Note: US DST (Mar–Nov) shifts EST→EDT (UTC-4).
//   UK/EU DST typically aligns but transitions differ in Mar/Apr & Oct/Nov.
//   During those weeks verify overlaps shift by 1 hour.

use_session      = input.bool(true,  "Enable Session Filter",                  group="Session Filter")
show_sess_bg     = input.bool(true,  "Highlight Sessions on Chart",             group="Session Filter")
use_london_ny    = input.bool(true,  "London–NY Overlap (Best — 8am–12pm EST)", group="Session Filter")
use_london       = input.bool(true,  "London Session (3am–12pm EST)",           group="Session Filter")
use_ny           = input.bool(true,  "New York Session (8am–5pm EST)",          group="Session Filter")
use_tokyo        = input.bool(false, "Tokyo/Asia Session (7pm–4am EST)",        group="Session Filter")
use_sydney       = input.bool(false, "Sydney Session (5pm–2am EST)",            group="Session Filter")
use_sam_mon      = input.bool(true,  "Sam's Monday Night (6pm–9pm EST)",        group="Session Filter")
use_sam_tueswed  = input.bool(true,  "Sam's Tue–Wed Morning (7am–12pm EST)",    group="Session Filter")
warn_thursday    = input.bool(true,  "Warn on Thursdays (Higher Risk)",         group="Session Filter")

// UTC session strings (standard time — adjust 1hr earlier during DST)
london_ny_utc   = "1300-1700"   // London–NY overlap, peak liquidity
london_utc      = "0800-1700"   // Full London session
ny_utc          = "1300-2200"   // Full New York session
tokyo_utc       = "0000-0900"   // Tokyo/Asia session
sydney_utc      = "2200-0700"   // Sydney session
sam_mon_utc     = "2300-0200"   // Sam's Monday night sweet spot
sam_tueswed_utc = "1200-1700"   // Sam's Tue–Wed morning window

in_london_ny  = time(timeframe.period, london_ny_utc)  != 0
in_london     = time(timeframe.period, london_utc)     != 0
in_ny         = time(timeframe.period, ny_utc)         != 0
in_tokyo      = time(timeframe.period, tokyo_utc)      != 0
in_sydney     = time(timeframe.period, sydney_utc)     != 0
in_sam_mon    = time(timeframe.period, sam_mon_utc)    != 0
in_sam_tw     = time(timeframe.period, sam_tueswed_utc) != 0

is_thursday   = dayofweek == dayofweek.thursday
is_weekend    = dayofweek == dayofweek.saturday or dayofweek == dayofweek.sunday

active_session = (use_london_ny   and in_london_ny)  or
                 (use_london       and in_london)      or
                 (use_ny           and in_ny)          or
                 (use_tokyo        and in_tokyo)        or
                 (use_sydney       and in_sydney)       or
                 (use_sam_mon      and in_sam_mon)      or
                 (use_sam_tueswed  and in_sam_tw)

in_session = not use_session or (active_session and not is_weekend)

// Session background highlights
bgcolor(show_sess_bg and in_london_ny ? color.new(color.green,  88) : na, title="London–NY Overlap")
bgcolor(show_sess_bg and in_london and not in_london_ny ? color.new(color.blue, 92) : na, title="London Session")
bgcolor(show_sess_bg and in_ny     and not in_london_ny ? color.new(color.aqua, 92) : na, title="NY Session")
bgcolor(show_sess_bg and in_tokyo  and not in_london    ? color.new(color.orange, 93) : na, title="Tokyo Session")
bgcolor(show_sess_bg and is_weekend ? color.new(color.gray, 85) : na, title="Weekend — No Trade")

// ─── MACRO BIAS ──────────────────────────────────────────────────────────────
bull_bias        = close > ma200
bear_bias        = close < ma200
above_smooth     = close > smooth_ma
above_200_cross  = ta.crossover(close, ma200)
below_200_cross  = ta.crossunder(close, ma200)
above_smooth_cross = ta.crossover(close, smooth_ma)

bgcolor(bull_bias ? color.new(color.green, 95) : color.new(color.red, 95), title="Bias Background")

// ─── GAP FROM 21 SMA ─────────────────────────────────────────────────────────
gap_from_21     = math.abs(close - ma21) / ma21 * 100
gapped_above_21 = close > ma21 and gap_from_21 >= gap_pct
gapped_below_21 = close < ma21 and gap_from_21 >= gap_pct

// ─── STOCHASTIC RSI ──────────────────────────────────────────────────────────
rsi_val    = ta.rsi(close, stoch_len)
stoch_raw  = ta.stoch(rsi_val, rsi_val, rsi_val, stoch_len)
k          = ta.sma(stoch_raw, stoch_k)
d          = ta.sma(k, stoch_d)
overbought = k >= ob_level and d >= ob_level
oversold   = k <= (100 - ob_level) and d <= (100 - ob_level)

// ─── ENTRY CONDITIONS ────────────────────────────────────────────────────────
touched_21_from_below = ta.crossover(close, ma21)
touched_21_from_above = ta.crossunder(close, ma21)

bars_since_200_cross  = ta.barssince(above_200_cross)

// "Fireworks": crossed 200 recently + touching 21 (strongest setup)
entry_fireworks = bull_bias and touched_21_from_below and bars_since_200_cross <= 10 and in_session

// Standard pullback to 21 while above 200
entry_pullback  = bull_bias and touched_21_from_below and not entry_fireworks and in_session

// "Smooth Boost": above smooth MA + touching 21 = extended target possible (113–118)
entry_smooth_boost = bull_bias and above_smooth and touched_21_from_below and in_session

// Short-side: below 200, gap below 21 (mirror of long)
entry_short = bear_bias and touched_21_from_above and in_session

// ─── STOP LOSS LOGIC ─────────────────────────────────────────────────────────
// Sam: stop loss goes below the 200 SMA (or below smooth MA for extended targets)
// Keep liquidation price well away — prefer 30–40x leverage, isolated margin
stop_below_200  = ma200 * 0.999   // just below the yellow line
stop_below_smooth = smooth_ma * 0.999

// ─── RISK CALCULATOR ─────────────────────────────────────────────────────────
// Computes position size from account + risk % + stop distance
risk_dollars    = account_size * (risk_pct / 100)
atr_val         = ta.atr(14)
stop_dist_pct   = (close - stop_below_200) / close * 100
tp_dist_pct     = stop_dist_pct * rr_ratio
tp_price        = close * (1 + tp_dist_pct / 100)

// ─── EXIT CONDITIONS ──────────────────────────────────────────────────────────
exit_gap_profit  = gapped_above_21
exit_overbought  = gapped_above_21 and overbought
exit_bear_flip   = below_200_cross
exit_short_cover = above_200_cross or (gapped_below_21 and oversold)

// ─── STRATEGY EXECUTION ──────────────────────────────────────────────────────
var bool partial_taken = false

if (entry_fireworks or entry_smooth_boost) and strategy.position_size == 0
    strategy.entry("Long_Fireworks", strategy.long, comment="Fireworks/Smooth")
    partial_taken := false

else if entry_pullback and strategy.position_size == 0
    strategy.entry("Long_Pullback", strategy.long, comment="21 Touch")
    partial_taken := false

if entry_short and strategy.position_size == 0
    strategy.entry("Short", strategy.short, comment="Short 21 Touch")

// Partial exit at first gap (default 75% off, keep runner)
if exit_gap_profit and strategy.position_size > 0 and not partial_taken
    strategy.close("Long_Fireworks", qty_percent=partial_pct, comment="Partial Gap Exit")
    strategy.close("Long_Pullback",  qty_percent=partial_pct, comment="Partial Gap Exit")
    partial_taken := true

// Full exit when overbought + gapped
if exit_overbought and strategy.position_size > 0
    strategy.close_all(comment="Gap+OB Full Exit")
    partial_taken := false

// Kill switch — 200 SMA bear flip
if exit_bear_flip and strategy.position_size > 0
    strategy.close_all(comment="Bear Flip — 200 Broken")
    partial_taken := false

if exit_short_cover and strategy.position_size < 0
    strategy.close_all(comment="Short Cover")

// ─── FIBONACCI LEVELS ────────────────────────────────────────────────────────
show_fib   = input.bool(true, "Show Fibonacci Levels", group="Fibonacci")
lookback   = input.int(50,    "Swing Lookback",         group="Fibonacci")

swing_high    = ta.highest(high, lookback)
swing_low     = ta.lowest(low,  lookback)
fib_range     = swing_high - swing_low
fib786_level  = swing_high - fib_range * 0.786
fib618_level  = swing_high - fib_range * 0.618
fib650_level  = swing_high - fib_range * 0.650

plot(show_fib ? fib786_level : na, "Fib 0.786",          color=color.new(color.orange, 40), style=plot.style_circles, linewidth=1)
plot(show_fib ? fib618_level : na, "Fib 0.618 (GP Low)",  color=color.new(color.lime, 40),   style=plot.style_circles, linewidth=1)
plot(show_fib ? fib650_level : na, "Fib 0.650 (GP High)", color=color.new(color.lime, 40),   style=plot.style_circles, linewidth=1)

// ─── SIGNALS ON CHART ────────────────────────────────────────────────────────
plotshape(entry_fireworks or entry_smooth_boost, title="Fireworks/Smooth Buy", location=location.belowbar, style=shape.triangleup,   color=color.new(color.yellow, 0), size=size.normal, text="FIRE")
plotshape(entry_pullback,   title="Pullback Buy",  location=location.belowbar, style=shape.triangleup,   color=color.new(color.green,  0), size=size.small,  text="21")
plotshape(entry_short,      title="Short Entry",   location=location.abovebar, style=shape.triangledown, color=color.new(color.red,    0), size=size.small,  text="SHORT")
plotshape(exit_overbought,  title="Gap+OB Sell",   location=location.abovebar, style=shape.triangledown, color=color.new(color.red,    0), size=size.small,  text="OB")
plotshape(exit_gap_profit and not exit_overbought, title="Gap Sell", location=location.abovebar, style=shape.triangledown, color=color.new(color.orange, 0), size=size.small, text="GAP")
plotshape(exit_bear_flip,   title="Bear Flip",     location=location.abovebar, style=shape.xcross,       color=color.new(color.red,    0), size=size.normal, text="BEAR")
plotshape(above_smooth_cross, title="Above Smooth", location=location.belowbar, style=shape.diamond,    color=color.new(color.teal,   0), size=size.tiny,   text="SMT")

// ─── RISK DASHBOARD (TABLE) ──────────────────────────────────────────────────
var table risk_table = table.new(position.top_right, 2, 9, border_width=1)

if show_risk_table and barstate.islast
    table.cell(risk_table, 0, 0, "RISK DASHBOARD",    text_color=color.white, bgcolor=color.new(color.blue,  20), text_size=size.small)
    table.cell(risk_table, 1, 0, "",                                           bgcolor=color.new(color.blue,  20))
    table.cell(risk_table, 0, 1, "Account",           text_color=color.white, bgcolor=color.new(color.gray,  70), text_size=size.small)
    table.cell(risk_table, 1, 1, "$" + str.tostring(account_size, "#,###"),   text_color=color.white, bgcolor=color.new(color.gray, 70), text_size=size.small)
    table.cell(risk_table, 0, 2, "Risk/Trade (1%)",   text_color=color.white, bgcolor=color.new(color.gray,  70), text_size=size.small)
    table.cell(risk_table, 1, 2, "$" + str.tostring(risk_dollars, "#.##"),    text_color=color.yellow, bgcolor=color.new(color.gray, 70), text_size=size.small)
    table.cell(risk_table, 0, 3, "Stop (below 200)",  text_color=color.white, bgcolor=color.new(color.gray,  70), text_size=size.small)
    table.cell(risk_table, 1, 3, str.tostring(stop_below_200, "#.##"),        text_color=color.red,    bgcolor=color.new(color.gray, 70), text_size=size.small)
    table.cell(risk_table, 0, 4, "TP Target (3:1)",   text_color=color.white, bgcolor=color.new(color.gray,  70), text_size=size.small)
    table.cell(risk_table, 1, 4, str.tostring(tp_price, "#.##"),              text_color=color.green,  bgcolor=color.new(color.gray, 70), text_size=size.small)
    table.cell(risk_table, 0, 5, "Gap from 21",       text_color=color.white, bgcolor=color.new(color.gray,  70), text_size=size.small)
    table.cell(risk_table, 1, 5, str.tostring(gap_from_21, "#.##") + "%",     text_color=gap_from_21 >= gap_pct ? color.red : color.green, bgcolor=color.new(color.gray, 70), text_size=size.small)
    table.cell(risk_table, 0, 6, "Bias",              text_color=color.white, bgcolor=color.new(color.gray,  70), text_size=size.small)
    table.cell(risk_table, 1, 6, bull_bias ? "BULL" : "BEAR",                 text_color=bull_bias ? color.green : color.red, bgcolor=color.new(color.gray, 70), text_size=size.small)
    table.cell(risk_table, 0, 7, "Session",           text_color=color.white, bgcolor=color.new(color.gray,  70), text_size=size.small)
    table.cell(risk_table, 1, 7, in_london_ny ? "LDN-NY (BEST)" : in_london ? "London" : in_ny ? "New York" : in_tokyo ? "Tokyo" : in_sydney ? "Sydney" : is_weekend ? "WEEKEND" : "Off-Hours", text_color=in_london_ny ? color.green : is_weekend ? color.red : color.yellow, bgcolor=color.new(color.gray, 70), text_size=size.small)
    table.cell(risk_table, 0, 8, "Thu Risk",          text_color=color.white, bgcolor=color.new(color.gray,  70), text_size=size.small)
    table.cell(risk_table, 1, 8, warn_thursday and is_thursday ? "CAUTION" : "OK", text_color=warn_thursday and is_thursday ? color.orange : color.green, bgcolor=color.new(color.gray, 70), text_size=size.small)

// ─── ALERTS ──────────────────────────────────────────────────────────────────
alertcondition(entry_fireworks,      title="Fireworks Entry",         message="FIREWORKS — Crossed 200 recently, now touching 21. Strong long setup.")
alertcondition(entry_smooth_boost,   title="Smooth Boost Entry",      message="SMOOTH BOOST — Above smooth MA + touching 21. Extended target possible.")
alertcondition(entry_pullback,       title="Pullback to 21",          message="21 SMA Touch — Pullback to 21 above 200. Standard long entry.")
alertcondition(entry_short,          title="Short Entry",             message="SHORT SETUP — Touching 21 below 200. Potential short entry.")
alertcondition(exit_gap_profit,      title="Gap Away — Take Profits", message="Gapped away from 21 SMA. Take partial or full profits.")
alertcondition(exit_bear_flip,       title="Bear Flip",               message="200 SMA broken. Macro bias flipped bearish. Close longs.")
alertcondition(above_smooth_cross,   title="Above Smooth MA",         message="Price crossed above Smooth MA. High probability of continuation — consider extended target.")

// ─── TODO (Polish at Home) ────────────────────────────────────────────────────
